/**
 * Employee Information Card Verification Plugin JavaScript
 * Author: Dongxing Zhang
 * Website: neijuli.cn
 */

(function($) {
    'use strict';
    
    // Main plugin object
    var EmployeeCardVerification = {
        
        // Initialize
        init: function() {
            this.bindEvents();
            this.setupModal();
        },
        
        // Bind events
        bindEvents: function() {
            // Form submit event
            $(document).on('submit', '#employee-verification-form', this.handleFormSubmit.bind(this));
            
            // Modal close event
            $(document).on('click', '.eic-close, .eic-modal', this.handleModalClose.bind(this));
            
            // ESC key to close modal
            $(document).on('keydown', this.handleKeyDown.bind(this));
            
            // Input enter key event
            $(document).on('keypress', '#employee-email-input', this.handleInputKeyPress.bind(this));
        },
        
        // Setup modal
        setupModal: function() {
            // Ensure modal exists
            if ($('#eic-modal').length === 0) {
                $('body').append(`
                    <div id="eic-modal" class="eic-modal" style="display: none;">
                        <div class="eic-modal-content">
                            <span class="eic-close">&times;</span>
                            <div id="eic-card-content"></div>
                        </div>
                    </div>
                `);
            }
        },
        
        // Handle form submit
        handleFormSubmit: function(e) {
            e.preventDefault();
            
            var email = $('#employee-email-input').val().trim();
            
            if (!this.validateEmail(email)) {
                this.showAlert('Please enter a valid email address');
                return;
            }
            
            this.verifyEmployee(email);
        },
        
        // Handle input enter key
        handleInputKeyPress: function(e) {
            if (e.which === 13) { // Enter key
                e.preventDefault();
                $('#employee-verification-form').submit();
            }
        },
        
        // Validate email format
        validateEmail: function(email) {
            var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return emailRegex.test(email);
        },
        
        // Show alert message
        showAlert: function(message) {
            // Prefer modern browser notifications
            if (typeof window.alert === 'function') {
                alert(message);
            } else {
                console.log(message);
            }
        },
        
        // Verify employee information
        verifyEmployee: function(email) {
            var self = this;
            
            // Show loading state
            this.showLoading();
            
            // Send AJAX request
            $.ajax({
                url: eic_ajax.ajax_url,
                type: 'POST',
                data: {
                    action: 'verify_employee',
                    email: email,
                    nonce: eic_ajax.nonce
                },
                timeout: 10000, // 10 second timeout
                success: function(response) {
                    self.hideLoading();
                    
                    if (response.success) {
                        if (response.data.found) {
                            self.showEmployeeCard(response.data.employee);
                        } else {
                            self.showErrorCard(response.data.message);
                        }
                    } else {
                        self.showAlert('Verification failed: ' + (response.data || 'Unknown error'));
                    }
                },
                error: function(xhr, status, error) {
                    self.hideLoading();
                    
                    var errorMessage = 'Network error, please try again later';
                    if (status === 'timeout') {
                        errorMessage = 'Request timeout, please check network connection';
                    } else if (xhr.status === 403) {
                        errorMessage = 'Insufficient permissions, please refresh the page and try again';
                    }
                    
                    self.showAlert(errorMessage);
                    console.error('AJAX Error:', status, error);
                }
            });
        },
        
        // Show loading state
        showLoading: function() {
            // Don't hide entire form, just show loading overlay
            $('#eic-loading').show();
            
            // Disable submit button
            $('.eic-verify-btn').prop('disabled', true);
        },
        
        // Hide loading state
        hideLoading: function() {
            $('#eic-loading').hide();
            
            // Enable submit button
            $('.eic-verify-btn').prop('disabled', false);
        },
        
        // Show employee card
        showEmployeeCard: function(employee) {
            var photoHtml = this.generatePhotoHtml(employee.photo_url);
            var positionText = employee.position || 'Employee';
            var departmentText = employee.department || 'Department not specified';
            
            var cardHtml = `
                <div class="eic-employee-card">
                    ${photoHtml}
                    <div class="eic-employee-name">${this.escapeHtml(employee.name)}</div>
                    <div class="eic-employee-position">${this.escapeHtml(positionText)}</div>
                    
                    <div class="eic-employee-info">
                        <div class="eic-info-item">
                            <svg class="eic-info-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                            </svg>
                            <span>${this.escapeHtml(employee.email)}</span>
                        </div>
                        <div class="eic-info-item">
                            <svg class="eic-info-icon" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path>
                            </svg>
                            <span>${this.escapeHtml(employee.phone)}</span>
                        </div>
                        <div class="eic-info-item">
                            <svg class="eic-info-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd"></path>
                                <path d="M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z"></path>
                            </svg>
                            <span>${this.escapeHtml(departmentText)}</span>
                        </div>
                    </div>
                    
                    <div class="eic-verified-badge">
                        ✓ Identity Verified
                    </div>
                </div>
            `;
            
            this.showModal(cardHtml);
        },
        
        // Generate photo HTML
        generatePhotoHtml: function(photoUrl) {
            if (photoUrl && photoUrl.trim() !== '') {
                return `<img src="${this.escapeHtml(photoUrl)}" alt="Employee Photo" class="eic-employee-photo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <div class="eic-employee-photo" style="display: none;">👤</div>`;
            } else {
                return '<div class="eic-employee-photo">👤</div>';
            }
        },
        
        // Show error card
        showErrorCard: function(message) {
            var cardHtml = `
                <div class="eic-error-card">
                    <div class="eic-error-icon">⚠️</div>
                    <div class="eic-error-title">Verification Failed</div>
                    <div class="eic-error-message">${this.escapeHtml(message)}</div>
                </div>
            `;
            
            this.showModal(cardHtml);
        },
        
        // Show modal
        showModal: function(content) {
            $('#eic-card-content').html(content);
            $('#eic-modal').fadeIn(300);
            
            // Focus on close button for keyboard navigation
            setTimeout(function() {
                $('.eic-close').focus();
            }, 300);
        },
        
        // Handle modal close
        handleModalClose: function(e) {
            if (e.target === e.currentTarget) {
                this.closeModal();
            }
        },
        
        // Handle keyboard events
        handleKeyDown: function(e) {
            if (e.keyCode === 27) { // ESC key
                this.closeModal();
            }
        },
        
        // Close modal
        closeModal: function() {
            $('#eic-modal').fadeOut(300);
            $('#employee-email-input').val('').focus();
        },
        
        // HTML escape
        escapeHtml: function(text) {
            if (typeof text !== 'string') {
                return '';
            }
            
            var map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            
            return text.replace(/[&<>"']/g, function(m) {
                return map[m];
            });
        }
    };
    
    // Initialize when DOM is ready
    $(document).ready(function() {
        EmployeeCardVerification.init();
    });
    
    // Expose object to global scope (for debugging)
    window.EmployeeCardVerification = EmployeeCardVerification;
    
})(jQuery);

// Compatibility check
if (typeof jQuery === 'undefined') {
    console.error('Employee Info Card plugin requires jQuery library support');
}

if (typeof eic_ajax === 'undefined') {
    console.error('Employee Info Card plugin: AJAX configuration not found');
}